{
	"name": "clui-vue",
	"version": "0.4.3",
	"description": "Vue 3 design-system components, tokens, and theme helpers (extracted for reuse).",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./package.json": "./package.json",
		"./tokens": "./src/ui/_tokens.scss",
		"./theme": "./src/ui/_theme.scss",
		"./styles/base": "./styles/base.scss",
		"./style.css": "./dist/style.css"
	},
	"files": [
		"dist",
		"src/ui/*.scss",
		"styles"
	],
	"sideEffects": true,
	"peerDependencies": {
		"vue": "^3.5.0"
	},
	"devDependencies": {
		"@types/node": "^22.19.1",
		"@vitejs/plugin-vue": "^6.0.2",
		"sass-embedded": "^1.99.0",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"vite-plugin-dts": "^4.5.0",
		"vue": "^3.5.25",
		"vue-tsc": "^3.1.6"
	},
	"scripts": {
		"build": "vue-tsc --noEmit -p tsconfig.json && vite build",
		"typecheck": "vue-tsc --noEmit -p tsconfig.json",
		"dev:website": "pnpm --dir website dev",
		"build:website": "pnpm run build && pnpm --dir website build",
		"typecheck:website": "pnpm --dir website run typecheck"
	},
	"keywords": [
		"vue",
		"vue3",
		"components",
		"design-system"
	],
	"license": "MIT",
	"packageManager": "pnpm@10.33.2",
	"repository": {
		"type": "git",
		"url": "https://github.com/mateo-meillon/clui-vue.git"
	},
	"homepage": "https://mateo-meillon.github.io/clui-vue/",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"@material-symbols/font-400": "^0.44.10"
	}
}
